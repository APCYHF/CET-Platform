{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://cet-platform-backend.up.railway.app/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://cet-platform-backend.up.railway.app/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
